l\"] }\n   clipboard = \"0.1\"\n   elevenlabs = \"0.1\"\n   ```\n\n3. **Implement the application**:\n   - Create a new file named `main.rs` and add the following code to implement the application.\n\n   ```rust\n   use reqwest::Client;\n   use tokio::fs::File;\n   use tokio::io::AsyncReadExt;\n   use clipboard::ClipboardContext;\n   use elevenlabs::Client as ElevenLabsClient;\n   use elevenlabs::Voice;\n   use elevenlabs::VoiceId;\n\n   #[tokio::main]\n   async fn main() -> Result<(), Box<dyn std::error::Error>> {\n       // Initialize the clipboard context\n       let mut ctx: ClipboardContext = ClipboardContext::new()?;\n\n       // Get the clipboard content\n       let clipboard_content = ctx.get_contents()?;\n\n       // Initialize the ElevenLabs client\n       let elevenlabs_client = ElevenLabsClient::new(\"YOUR_ELEVENLABS_API_KEY\")?;\n\n       // Choose a voice (you can replace \"voice_id\" with the actual voice ID you want to use)\n       let voice_id = VoiceId::new(\"voice_id\")?;\n       let voice = elevenlabs_client.get_voice(voice_id).await?;\n\n       // Convert the clipboard content to speech\n       let audio_data = elevenlabs_client.synthesize_text(&clipboard_content, &voice).await?;\n\n       // Save the audio data to a file\n       let mut file = File::create(\"output.mp3\").await?;\n       file.write_all(&audio_data).await?;\n\n       // Play the audio file (you can use a library like `rodio` for this)\n       // For simplicity, we'll just save the audio data to a file\n\n       println!(\"Audio saved to output.mp3\");\n\n       Ok(())\n   }\n   ```\n\n4. **Replace placeholders**:\n   - Replace `\"YOUR_ELEVENLABS_API_KEY\"` with your actual ElevenLabs API key.\n   - Replace `\"voice_id\"` with the actual voice ID you want to use.\n\n5. **Run the application**:\n   - Build and run your application using `cargo run`.\n\n   ```sh\n   cargo run\n   ```\n\nThis code sets up a basic Rust application that reads the contents of the clipboard, converts it to speech using the ElevenLabs API, and saves the audio data to a file named `output.mp3`. You can further enhance this application by adding features like playing the audio directly or integrating with other TTS engines."], "errors": ["", ""], "mean_ttft_ms": 33.32445299997744, "median_ttft_ms": 33.32445299997744, "std_ttft_ms": 0.10761199996522919, "p99_ttft_ms": 33.42991275994336, "mean_tpot_ms": 13.43939219305354, "median_tpot_ms": 13.43939219305354, "std_tpot_ms": 0.09552098966639483, "p99_tpot_ms": 13.533002762926607, "mean_itl_ms": 13.50755611529067, "median_itl_ms": 13.522061000003305, "std_itl_ms": 0.29790495251387594, "p99_itl_ms": 14.394922399796997}